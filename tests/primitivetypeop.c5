// this is for testing the primitive type extending using typeop

#namespaces 0;
include <std.c5h>

typeop string == (string a, string b) {
    if (a.length() != b.length()) {
        return 0;
    }
    for (int i = 0; i < a.length(); i = i + 1) {
        if (a[i] != b[i]) {
            return 0;
        }
    }
    return 1;
}

typeop string != (string a, string b) {
    if (a.length() != b.length()) {
        return 1;
    }
    for (int i = 0; i < a.length(); i = i + 1) {
        if (a[i] != b[i]) {
            return 1;
        }
    }
    return 0;
}

typeop string.join(string str, string c) {
    return str + (string)c;
}

typeop int == (int a, any b) {
    if (gettype(b) == c5core::types::INT) {
        return a == (int)b;
    } else if (gettype(b) == c5core::types::STRING) {
        int i_b = (int)b;
        return a == i_b;
    }
}

void main() {
    if (12 == "12") {
        printf("yey\n");
    } else {
        printf("nooooo :(\n");
    }

    if ("Hello" == "Hello") {
        printf("Yey!\n");
    } else {
        printf("Meh :(\n");
    }
}